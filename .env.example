# ── LLM Provider (one required) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── Downstream: Sentinel-L7 ───────────────────────────────────────────────────
# Redis Streams delivery — Upstash or local Redis
SENTINEL_REDIS_URL=redis://localhost:6379
SENTINEL_L7_URL=http://localhost:8001  # optional, retained for health checks

# ── Upstream: EventHorizon (optional — only for WebSocket consumer mode) ──────
# EVENTHORIZON_WS_URL=ws://localhost:3000/live

# ── Observability ─────────────────────────────────────────────────────────────
# LOGFIRE_TOKEN=...
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318  # local Grafana/Tempo stack

# ── Tuning (all optional — defaults shown) ────────────────────────────────────
# LLM_MODEL=gpt-4o-mini
# INSTRUCTOR_MAX_RETRIES=3
# LOG_LEVEL=INFO
# PIPELINE_QUEUE_SIZE=100
# PIPELINE_WORKERS=3
